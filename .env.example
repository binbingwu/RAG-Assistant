# Copy this file to .env and fill in your values.

# DeepSeek uses an OpenAI-compatible chat completions API.
DEEPSEEK_API_KEY=replace_me
DEEPSEEK_API_BASE=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# Keep this pointing at the document folder. The app reads from it but does not modify it.
RAG_SOURCE_DIR=C:\Users\bwu\OneDrive - Metercor Inc\Attachments\Desktop\RAG\Winnipeg documentation

# Local index location inside this independent project.
RAG_STORAGE_DIR=storage
RAG_TOP_K=6

